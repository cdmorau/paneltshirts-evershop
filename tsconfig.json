{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@panel-theme/*": ["extensions/panel-theme/*"]
    }
  },
  "include": ["extensions/panel-theme/**/*.ts", "extensions/panel-theme/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
